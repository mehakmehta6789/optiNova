<%- include('../partials/header', { title }) %>

<section class="card">
  <h1>Category Management</h1>
  <form action="/admin/categories" method="POST" class="auth-form">
    <input name="name" placeholder="Category Name" required />
    <input name="slug" placeholder="category-slug" required />
    <button class="btn" type="submit">Add Category</button>
  </form>
</section>

<section class="card">
  <h2>Existing Categories</h2>
  <% categories.forEach((category) => { %>
    <div class="row-between line">
      <p><strong><%= category.name %></strong> (<%= category.slug %>)</p>
      <form action="/admin/categories/<%= category._id %>?_method=DELETE" method="POST">
        <button class="btn btn-danger" type="submit">Delete</button>
      </form>
    </div>
  <% }) %>
</section>

<%- include('../partials/footer') %>
