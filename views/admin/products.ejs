<%- include('../partials/header', { title }) %>

<section class="card">
  <h1>Product Management</h1>
  <form action="/admin/products" method="POST" enctype="multipart/form-data" class="auth-form">
    <input name="name" placeholder="Name" required />
    <input name="brand" placeholder="Brand" required />
    <textarea name="description" placeholder="Description"></textarea>
    <select name="category" required>
      <option value="">Select Category</option>
      <% categories.forEach((category) => { %>
        <option value="<%= category._id %>"><%= category.name %></option>
      <% }) %>
    </select>
    <input name="frameType" placeholder="Frame Type" />
    <input name="lensType" placeholder="Lens Type" />
    <input name="gender" placeholder="Gender" />
    <input type="number" name="price" min="0" step="0.01" placeholder="Price" required />
    <input type="number" name="stock" min="0" placeholder="Stock" required />
    <input type="file" name="image" accept="image/*" />
    <button class="btn" type="submit">Add Product</button>
  </form>
</section>

<section class="card">
  <h2>All Products</h2>
  <% products.forEach((product) => { %>
    <div class="line">
      <form action="/admin/products/<%= product._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="auth-form">
        <input name="name" value="<%= product.name %>" required />
        <input name="brand" value="<%= product.brand %>" required />
        <input name="price" type="number" step="0.01" min="0" value="<%= product.price %>" required />
        <input name="stock" type="number" min="0" value="<%= product.stock %>" required />
        <select name="category" required>
          <% categories.forEach((category) => { %>
            <option value="<%= category._id %>" <%= String(product.category._id) === String(category._id) ? 'selected' : '' %>>
              <%= category.name %>
            </option>
          <% }) %>
        </select>
        <input name="frameType" value="<%= product.frameType %>" />
        <input name="lensType" value="<%= product.lensType %>" />
        <input name="gender" value="<%= product.gender %>" />
        <textarea name="description"><%= product.description %></textarea>
        <input type="file" name="image" accept="image/*" />
        <button class="btn" type="submit">Update</button>
      </form>
      <div class="row-actions">
      <form action="/admin/products/<%= product._id %>?_method=DELETE" method="POST">
          <button class="btn btn-danger" type="submit">Delete</button>
      </form>
      </div>
    </div>
  <% }) %>
</section>

<%- include('../partials/footer') %>
